/* pages/receive-delivery/receive-delivery.wxss */
.page-header {
  background: linear-gradient(135deg, #1296db 0%, #0b7ec8 100%);
  color: white;
  padding: 40rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
  position: relative;
  min-height: 120rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.service-options {
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.option-card {
  display: flex;
  align-items: center;
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.option-card:active {
  transform: scale(0.98);
  transition: transform 0.1s;
}

.option-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.option-info {
  flex: 1;
}

.option-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.option-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.option-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.recent-section {
  margin: 30rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #1296db;
}

.request-list {
  margin-bottom: 30rpx;
}

.request-item {
  background-color: white;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.request-info {
  flex: 1;
  margin-right: 20rpx;
}

.request-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.request-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-item {
  font-size: 24rpx;
  color: #666;
}

.detail-item.price {
  color: #e74c3c;
  font-weight: bold;
}

.request-action {
  flex-shrink: 0;
}

.action-btn {
  background-color: #1296db;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  min-width: 80rpx;
}

.action-btn:active {
  background-color: #0b7ec8;
}

.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 页面头部返回按钮 */
.header-back {
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  font-size: 60rpx;
  color: #ffffff;
  font-weight: bold;
  padding: 20rpx;
  line-height: 1;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.header-back:active {
  background-color: rgba(0, 0, 0, 0.5);
  transform: scale(0.9);
}

/* 发布选项菜单样式 */
.publish-menu {
  padding: 0 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-item {
  display: flex;
  align-items: center;
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 600rpx;
}

.menu-item:active {
  transform: scale(0.98);
  transition: transform 0.1s;
}

.menu-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.menu-info {
  flex: 1;
  text-align: center;
}

.menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.menu-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 使用说明样式 */
.help-section {
  background-color: white;
  border-radius: 12rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.help-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.help-content {
  line-height: 1.6;
}

.help-item {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.help-item:last-child {
  margin-bottom: 0;
}


/* 发布表单样式 */
.publish-form {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.form-content {
  background-color: white;
  border-radius: 12rpx;
  max-height: 80vh;
  max-width: 600rpx;
  width: 100%;
  overflow-y: auto;
  margin: 0 auto;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.form-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.form-close:active {
  color: #666;
}

.form-item {
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-of-type {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.required {
  color: #ff4757;
  font-size: 24rpx;
}

.form-input {
  width: 100%;
  padding: 5rpx 20rpx 5rpx 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #fff;
  box-sizing: border-box;
  height: 80rpx;
  vertical-align: bottom;
  text-align: left;
  line-height: 70rpx;
}

.form-input:focus {
  border-color: #1296db;
}

/* placeholder文本底对齐 */
.form-input::placeholder {
  font-size: 22rpx;
  color: #999;
  line-height: 70rpx;
  vertical-align: bottom;
}

.form-actions {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
}

.cancel-btn,
.submit-btn {
  flex: 1;
  padding: 25rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.cancel-btn:active {
  background-color: #e0e0e0;
}

.submit-btn {
  background-color: #1296db;
  color: white;
}

.submit-btn:active:not([disabled]) {
  background-color: #0b7ec8;
}

.submit-btn[disabled] {
  background-color: #ccc;
  color: #999;
}

.stats-section {
  background-color: white;
  border-radius: 12rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx;
}

.stats-item {
  text-align: center;
  padding: 20rpx 10rpx;
  border-radius: 8rpx;
  background-color: #f8f9fa;
}

.stats-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #1296db;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
}

/* 代取快递列表页面样式 */
.filter-bar {
  background-color: white;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.filter-buttons {
  display: flex;
  gap: 20rpx;
}

.filter-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  transition: all 0.2s;
}

.filter-btn.active {
  background-color: #1296db;
  color: white;
}

.filter-btn:active {
  transform: scale(0.95);
}

.selection-info {
  font-size: 24rpx;
  color: #1296db;
  font-weight: 500;
}

.action-bar {
  background-color: white;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.select-icon {
  font-size: 32rpx;
}

.confirm-btn {
  background-color: #ccc;
  color: white;
  padding: 15rpx 30rpx;
  border-radius: 25rpx;
  font-size: 28rpx;
  transition: all 0.2s;
}

.confirm-btn.active {
  background-color: #1296db;
}

.confirm-btn:active {
  transform: scale(0.95);
}

.package-list {
  padding: 20rpx;
}

.package-item {
  background-color: white;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.package-content {
  display: flex;
  padding: 15rpx 20rpx;
}

.select-box {
  margin-right: 20rpx;
  display: flex;
  align-items: flex-start;
  padding-top: 10rpx;
}

.package-info {
  flex: 1;
}

.package-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.package-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #1296db;
}

.status-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-tag.pending {
  background-color: #fff3cd;
  color: #856404;
}

.status-tag.completed {
  background-color: #d1edff;
  color: #0c5aa6;
}

.package-details {
  margin-bottom: 0;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-line {
  display: block;
  width: 100%;
  margin-bottom: 8rpx;
}

.detail-line:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
}

.pickup-code {
  font-weight: bold;
  color: #e74c3c;
  background-color: #ffeaa7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-family: 'Courier New', monospace;
}

.phone {
  font-size: 24rpx;
  color: #1296db;
  text-decoration: underline;
}

.package-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e74c3c;
}

/* 返回主页按钮样式 */
.bottom-actions {
  padding: 30rpx 40rpx;
  background-color: transparent;
  margin-bottom: 40rpx;
}

.home-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  background: linear-gradient(135deg, #1296db 0%, #0b7ec8 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 25rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(18, 150, 219, 0.3);
  transition: all 0.2s ease;
}

.home-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(18, 150, 219, 0.4);
}

.home-btn::after {
  border: none;
}

.home-icon {
  font-size: 32rpx;
}

/* 发布成功模态框样式 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.success-content {
  background-color: white;
  border-radius: 12rpx;
  max-width: 500rpx;
  width: 100%;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.success-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #eee;
  background: linear-gradient(135deg, #1296db 0%, #0b7ec8 100%);
  color: white;
}

.success-title {
  font-size: 32rpx;
  font-weight: bold;
}

.success-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1;
  cursor: pointer;
  padding: 5rpx;
}

.success-close:active {
  color: rgba(255, 255, 255, 0.6);
}

.success-body {
  padding: 30rpx;
}

.success-message {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 25rpx;
  text-align: center;
  font-weight: 500;
}

.success-details {
  background-color: #f8f9fa;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 25rpx;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
  line-height: 1.5;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.detail-value.pickup-code {
  font-weight: bold;
  color: #e74c3c;
  background-color: #ffeaa7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-family: 'Courier New', monospace;
  display: inline-block;
  margin-top: 2rpx;
}

.success-footer {
  font-size: 24rpx;
  color: #1296db;
  text-align: center;
  font-weight: 500;
  font-style: italic;
}

.success-actions {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  justify-content: center;
}

.success-btn {
  background: linear-gradient(135deg, #1296db 0%, #0b7ec8 100%);
  color: white;
  border: none;
  border-radius: 25rpx;
  padding: 18rpx 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(18, 150, 219, 0.3);
  transition: all 0.2s ease;
}

.success-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(18, 150, 219, 0.4);
}

.success-btn::after {
  border: none;
}

/* 响应式调整 */
@media screen and (max-width: 400px) {
  .detail-row {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .label {
    width: auto;
    margin-bottom: 4rpx;
  }
  
  .value {
    margin-right: 0;
  }

  .bottom-actions {
    padding: 25rpx 30rpx;
    margin-bottom: 30rpx;
  }

  .home-btn {
    padding: 20rpx 35rpx;
    font-size: 28rpx;
  }

  .home-icon {
    font-size: 28rpx;
  }

  .success-modal {
    padding: 30rpx;
  }

  .success-content {
    max-width: none;
    width: 100%;
  }

  .detail-label {
    width: 100rpx;
    font-size: 24rpx;
  }

  .detail-value {
    font-size: 24rpx;
  }

  .success-btn {
    padding: 15rpx 40rpx;
    font-size: 26rpx;
  }
}
