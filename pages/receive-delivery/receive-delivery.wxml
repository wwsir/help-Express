<!-- pages/receive-delivery/receive-delivery.wxml -->
<view class="container">
  <!-- 主页面 -->
  <view wx:if="{{currentPage === 'main'}}">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-title">快递服务</view>
      <view class="header-desc">小程序说明：快递收件人支付一定的费用给代取员，代取员帮忙把快递从镇送到村。</view>
    </view>

    <!-- 服务选项 -->
    <view class="service-options">
      <view class="option-card" bindtap="goToReceiveExpress">
        <view class="option-icon">📦</view>
        <view class="option-info">
          <view class="option-title">收取快递</view>
          <view class="option-desc">登记取件信息,让有交通工具的乡亲帮您取快递,每件默认2元代取费</view>
        </view>
      </view>

      <view class="option-card" bindtap="goToHelpExpress">
        <view class="option-icon">🚚</view>
        <view class="option-info">
          <view class="option-title">代取快递</view>
          <view class="option-desc">如果您有交通工具又有责任心,欢迎帮助乡亲们代取快递</view>
        </view>
      </view>
    </view>

    <!-- 最新代取 -->
    <view class="recent-section">
      <view class="section-header">
        <view class="section-title">最新代取</view>
        <view class="section-more" bindtap="viewAllRequests">查看更多</view>
      </view>
      
      <view class="request-list">
        <view class="request-item" wx:for="{{recentRequests}}" wx:key="id">
          <view class="request-info" bindtap="showRequestDetails" data-id="{{item.id}}">
            <view class="request-detail">
              <text class="detail-item">📦 {{item.trackingNumber || '快递单号：' + item.id}}</text>
              <text class="detail-item status-{{item.status === '待取件' ? 'pending' : 'completed'}}">{{item.status || '待取件'}}</text>
            </view>
          </view>
          <view class="request-action">
            <button class="action-btn" bindtap="takeOrder" data-id="{{item.id}}">接单</button>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{recentRequests.length === 0}}">
        <view class="empty-icon">🈳</view>
        <view class="empty-text">暂无最新代取</view>
      </view>
    </view>

    <!-- 统计信息 -->
    <view class="stats-section">
      <view class="stats-grid">
        <view class="stats-item">
          <view class="stats-number">该村代取员</view>
          <view class="stats-label">在线帮手</view>
        </view>
        <view class="stats-item">
          <view class="stats-number">{{stats.todayRequests}}</view>
          <view class="stats-label">取件需求</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 收取快递页面 -->
  <view wx:if="{{currentPage === 'publish'}}">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-back" bindtap="backToMain">‹</view>
      <view class="header-title">收取快递</view>
      <view class="header-desc">选择发布收件信息的方式</view>
    </view>

    <!-- 发布选项菜单 -->
    <view class="publish-menu">
      <view class="menu-item" bindtap="selectTextPublish">
        <view class="menu-icon">📝</view>
        <view class="menu-info">
          <view class="menu-title">文字发布收件信息</view>
          <view class="menu-desc">手动输入收件人信息、快递单号等</view>
        </view>
      </view>

      <view class="menu-item" bindtap="selectImagePublish">
        <view class="menu-icon">📷</view>
        <view class="menu-info">
          <view class="menu-title">图片发布收件信息</view>
          <view class="menu-desc">拍照上传取件码截图（开发中）</view>
        </view>
      </view>
    </view>

    <!-- 使用说明 -->
    <view class="help-section">
      <view class="help-title">使用说明</view>
      <view class="help-content">
        <view class="help-item">• 文字发布：手动输入收件信息，适合已知详细信息</view>
        <view class="help-item">• 图片发布：直接拍摄取件码，快速便捷（即将上线）</view>
        <view class="help-item">• 发布后会有热心用户帮您代取快递</view>
        <view class="help-item">• 请确保信息准确，以便顺利完成代取</view>
      </view>
    </view>
  </view>

  <!-- 所有代取需求页面 -->
  <view wx:if="{{currentPage === 'allRequests'}}">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-back" bindtap="backToMain">‹</view>
      <view class="header-title">所有代取需求</view>
      <view class="header-desc">查看所有可接单的快递</view>
    </view>

    <!-- 快递列表 -->
    <view class="package-list">
      <view class="package-item" wx:for="{{availableRequests}}" wx:key="id">
        <view class="package-content">
          <!-- 快递单号 -->
          <view class="package-number" bindtap="showRequestDetails" data-id="{{item.id}}">{{index + 1}}. {{item.trackingNumber}}</view>
          
          <!-- 快递状态 -->
          <view class="status-tag pending">{{item.status}}</view>

          <!-- 接单按钮 -->
          <view class="request-action">
            <button class="action-btn" bindtap="takeOrderFromAllRequests" data-id="{{item.id}}">接单</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{availableRequests.length === 0}}">
      <view class="empty-icon">📦</view>
      <view class="empty-text">暂无可接单的快递</view>
    </view>

  </view>

  <!-- 代取快递列表页面 -->
  <view wx:if="{{currentPage === 'pickupList'}}">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-back" bindtap="backToMain">‹</view>
      <view class="header-title">代取快递</view>
      <view class="header-desc">选择要代取的快递包裹</view>
    </view>

    <!-- 筛选和统计栏 -->
    <view class="filter-bar">
      <view class="filter-buttons">
        <view class="filter-btn active" bindtap="filterPackages" data-status="全部">全部</view>
        <view class="filter-btn" bindtap="filterPackages" data-status="待取件">待取件</view>
        <view class="filter-btn" bindtap="filterPackages" data-status="已取件">已取件</view>
      </view>
      <view class="selection-info" wx:if="{{selectedCount > 0}}">
        已选 {{selectedCount}} 件
      </view>
    </view>

    <!-- 操作栏 -->
    <view class="action-bar" wx:if="{{waitingPackagesCount > 0}}">
      <view class="select-all-btn" bindtap="toggleSelectAll">
        <view class="select-icon">{{allWaitingSelected ? '☑️' : '☐'}}</view>
        <text>全选待取件</text>
      </view>
      <view class="action-buttons">
        <view class="confirm-btn {{selectedCount > 0 ? 'active' : ''}}" bindtap="confirmPickup">
          确认取件 {{selectedCount > 0 ? '(' + selectedCount + ')' : ''}}
        </view>
        <view class="self-pickup-btn {{selectedCount > 0 ? 'active' : ''}}" bindtap="confirmSelfPickup">
          确认自取 {{selectedCount > 0 ? '(' + selectedCount + ')' : ''}}
        </view>
      </view>
    </view>

    <!-- 快递列表 -->
    <view class="package-list">
      <view class="package-item" wx:for="{{pickupPackages}}" wx:key="id">
        <view class="package-content">
          <!-- 选择框 -->
          <view class="select-box" wx:if="{{item.status === '待取件'}}" bindtap="togglePackageSelection" data-id="{{item.id}}">
            <view class="select-icon">{{item.selected ? '☑️' : '☐'}}</view>
          </view>
          
          <!-- 快递信息 -->
          <view class="package-info" bindtap="showPackageDetails" data-id="{{item.id}}">
            <view class="package-header">
              <view class="package-number">编号: {{index + 1}}</view>
            </view>
            
            <view class="detail-line">
                <text class="label">快递单号:</text>
                <text class="value">{{item.trackingNumber}}</text>
                <view class="status-tag pickup-page-status {{item.status === '待取件' ? 'pending' : 'completed'}}">{{item.status}}</view>
              </view>
            <view class="package-details">
              <view class="detail-line">
                <text class="label">收件人:</text>
                <text class="value">{{item.receiverName}}</text>
              </view>
              
            </view>
          </view>

          <!-- 详情箭头 -->
          <view class="package-arrow" bindtap="showPackageDetails" data-id="{{item.id}}">
            <view class="arrow-icon">></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{pickupPackages.length === 0}}">
      <view class="empty-icon">📦</view>
      <view class="empty-text">暂无快递信息</view>
    </view>
  </view>

  <!-- 收件信息发布表单 -->
  <view class="publish-form" wx:if="{{showPublishForm}}">
    <view class="form-content">
      <view class="form-header">
        <view class="form-title">发布收件信息</view>
        <view class="form-close" bindtap="closePublishForm">×</view>
      </view>
      
      <view class="form-item">
        <view class="form-label">收件人真名 <text class="required">*</text></view>
        <input 
          class="form-input" 
          placeholder="收件人姓名" 
          value="{{publishForm.receiverName}}" 
          bindinput="onReceiverNameInput"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <view class="form-label">收件人手机号 <text class="required">*</text></view>
        <input 
          class="form-input" 
          placeholder="手机号" 
          value="{{publishForm.receiverPhone}}" 
          bindinput="onReceiverPhoneInput"
          type="number"
          maxlength="11"
        />
      </view>

      <view class="form-item">
        <view class="form-label">快递单号 <text class="required">*</text></view>
        <input 
          class="form-input" 
          placeholder="快递单号" 
          value="{{publishForm.trackingNumber}}" 
          bindinput="onTrackingNumberInput"
          maxlength="30"
        />
      </view>

      <view class="form-item">
        <view class="form-label">快递取件码 <text class="required">*</text></view>
        <input 
          class="form-input" 
          placeholder="取件码" 
          value="{{publishForm.pickupCode}}" 
          bindinput="onPickupCodeInput"
          maxlength="10"
        />
      </view>

      <view class="form-actions">
        <button class="cancel-btn" bindtap="closePublishForm">取消</button>
        <button class="submit-btn" bindtap="submitPublishForm" disabled="{{!isFormValid}}">发布</button>
      </view>
    </view>
  </view>

  <!-- 发布成功详情模态框 -->
  <view class="success-modal" wx:if="{{showSuccessModal}}">
    <view class="success-content">
      <view class="success-header">
        <view class="success-title">发布成功</view>
        <view class="success-close" bindtap="closeSuccessModal">×</view>
      </view>
      
      <view class="success-body">
        <view class="success-message">收件信息已发布：</view>
        
        <view class="success-details">
          <view class="detail-item">
            <view class="detail-label">收件人：</view>
            <view class="detail-value">{{successDetails.receiverName}}</view>
          </view>
          
          <view class="detail-item">
            <view class="detail-label">手机号：</view>
            <view class="detail-value">{{successDetails.receiverPhone}}</view>
          </view>
          
          <view class="detail-item">
            <view class="detail-label">快递单号：</view>
            <view class="detail-value">{{successDetails.trackingNumber}}</view>
          </view>
          
          <view class="detail-item">
            <view class="detail-label">取件码：</view>
            <view class="detail-value pickup-code">{{successDetails.pickupCode}}</view>
          </view>
        </view>
        
        <view class="success-footer">等待好心人帮您代取！</view>
      </view>
      
      <view class="success-actions">
        <button class="success-btn" bindtap="closeSuccessModal">确定</button>
      </view>
    </view>
  </view>

  <!-- 快递详情模态框 -->
  <view class="detail-modal" wx:if="{{showDetailModal}}">
    <view class="detail-content">
      <view class="detail-header">
        <view class="detail-title">{{detailModalType === 'request' ? '代取需求详情' : '快递详情'}}</view>
        <view class="detail-close" bindtap="closeDetailModal">×</view>
      </view>
      
      <view class="detail-body">
        <!-- 代取需求详情 -->
        <view wx:if="{{detailModalType === 'request'}}">
          <view class="detail-section">
            <view class="section-title">📦 基本信息</view>
            <view class="detail-grid">
              <view class="detail-row">
                <view class="label">快递单号：</view>
                <view class="value">{{selectedDetail.trackingNumber}}</view>
              </view>
              <view class="detail-row">
                <view class="label">取件地址：</view>
                <view class="value">快递代收点</view>
              </view>
              <view class="detail-row">
                <view class="label">期望时间：</view>
                <view class="value">默认时间</view>
              </view>
              <view class="detail-row">
                <view class="label">服务费用：</view>
                <view class="value price">¥{{selectedDetail.price || '2' }}</view>
              </view>
            </view>
          </view>

          <view class="detail-section">
            <view class="section-title">📋 服务说明</view>
            <view class="service-desc">
            • 核对快递信息后取件\n• 服务费用将在确认送达后支付
            </view>
          </view>

          <view class="detail-actions">
            <button class="detail-btn secondary" bindtap="closeDetailModal">关闭</button>
            <button class="detail-btn primary" bindtap="takeOrderFromDetail" data-id="{{selectedDetail.id}}">立即接单</button>
          </view>
        </view>

        <!-- 快递包裹详情 -->
        <view wx:if="{{detailModalType === 'package'}}">
          <view class="detail-section">
            <view class="section-title">📦 快递信息</view>
            <view class="detail-grid">
              <view class="detail-row">
                <view class="label">快递公司：</view>
                <view class="value">{{selectedDetail.company}}</view>
              </view>
              <view class="detail-row">
                <view class="label">运单号码：</view>
                <view class="value">{{selectedDetail.trackingNumber}}</view>
              </view>
              <view class="detail-row">
                <view class="label">取件码：</view>
                <view class="value pickup-code">{{selectedDetail.pickupCode}}</view>
              </view>
              <view class="detail-row">
                <view class="label">取件地址：</view>
                <view class="value">{{selectedDetail.location}}</view>
              </view>
            </view>
          </view>

          <view class="detail-section">
            <view class="section-title">👤 收件信息</view>
            <view class="detail-grid">
              <view class="detail-row">
                <view class="label">收件人：</view>
                <view class="value">{{selectedDetail.receiverName}}</view>
              </view>
              <view class="detail-row">
                <view class="label">联系电话：</view>
                <view class="value">{{selectedDetail.phone}}</view>
              </view>
            </view>
          </view>

          <view class="detail-section">
            <view class="section-title">📊 状态信息</view>
            <view class="detail-grid">
              <view class="detail-row">
                <view class="label">当前状态：</view>
                <view class="value status-{{selectedDetail.status === '待取件' ? 'pending' : 'completed'}}">{{selectedDetail.status}}</view>
              </view>
              <view class="detail-row">
                <view class="label">发布时间：</view>
                <view class="value">{{selectedDetail.publishTime}}</view>
              </view>
              <view class="detail-row" wx:if="{{selectedDetail.pickupTime}}">
                <view class="label">取件时间：</view>
                <view class="value">{{selectedDetail.pickupTime}}</view>
              </view>
            </view>
          </view>

          <view class="detail-actions" wx:if="{{selectedDetail.status === '待取件'}}">
            <button class="detail-btn secondary" bindtap="closeDetailModal">关闭</button>
            <button class="detail-btn primary" bindtap="confirmPickupFromDetail" data-id="{{selectedDetail.id}}">确认取件</button>
            <button class="detail-btn green" bindtap="confirmSelfPickupFromDetail" data-id="{{selectedDetail.id}}">确认自取</button>
          </view>
          <view class="detail-actions" wx:else>
            <button class="detail-btn secondary" bindtap="closeDetailModal">关闭</button>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
