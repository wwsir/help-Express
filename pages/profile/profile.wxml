<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card" wx:if="{{isLoggedIn}}">
    <view class="user-avatar">
      <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" class="avatar-img"></image>
    </view>
    <view class="user-info">
      <view class="user-name">{{userInfo.nickName || '用户'}}</view>
      <view class="user-desc">快递帮取服务用户</view>
    </view>
  </view>

  <!-- 未登录状态 -->
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <view class="prompt-icon">👤</view>
    <view class="prompt-text">请先登录享受更多服务</view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 登录选项 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="goToLogin" wx:if="{{!isLoggedIn}}">
        <view class="menu-icon">👤</view>
        <view class="menu-text">登录</view>
        <view class="menu-badge">享受更多服务</view>
        <view class="menu-arrow">></view>
      </view>
      
      <view class="menu-item logout" bindtap="handleLogout" wx:if="{{isLoggedIn}}">
        <view class="menu-icon">🚪</view>
        <view class="menu-text">退出登录</view>
        <view class="menu-arrow">></view>
      </view>
    </view>
    
    <!-- 快递相关功能 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="goToMyReceiveOrders">
        <view class="menu-icon">📦</view>
        <view class="menu-text">我的收取快递</view>
        <view class="menu-badge" wx:if="{{stats.myReceiveOrders > 0}}">{{stats.myReceiveOrders}}</view>
        <view class="menu-arrow">></view>
      </view>
      
      <view class="menu-item" bindtap="goToMyHelpOrders">
        <view class="menu-icon">🚚</view>
        <view class="menu-text">我的代取快递</view>
        <view class="menu-badge" wx:if="{{stats.myHelpOrders > 0}}">{{stats.myHelpOrders}}</view>
        <view class="menu-arrow">></view>
      </view>
    </view>
    
    <!-- 其他功能 -->
    <view class="menu-group">
      <view class="menu-item" bindtap="goToMyEarnings">
        <view class="menu-icon">💰</view>
        <view class="menu-text">我的钱包</view>
        <view class="menu-arrow">></view>
      </view>
      
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-icon">⚙️</view>
        <view class="menu-text">设置</view>
        <view class="menu-arrow">></view>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToHelp">
        <view class="menu-icon">❓</view>
        <view class="menu-text">帮助中心</view>
        <view class="menu-arrow">></view>
      </view>
      
      <view class="menu-item" bindtap="goToAbout">
        <view class="menu-icon">ℹ️</view>
        <view class="menu-text">关于我们</view>
        <view class="menu-arrow">></view>
      </view>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section" wx:if="{{isLoggedIn}}">
    <view class="stats-title">我的统计</view>
    <view class="stats-grid">
      <view class="stats-item">
        <view class="stats-number">{{stats.helpCount}}</view>
        <view class="stats-label">帮取次数</view>
      </view>
      <view class="stats-item">
        <view class="stats-number">{{stats.publishCount}}</view>
        <view class="stats-label">发布次数</view>
      </view>
      <view class="stats-item">
        <view class="stats-number">¥{{stats.totalEarning}}</view>
        <view class="stats-label">累计收益</view>
      </view>
      <view class="stats-item">
        <view class="stats-number">{{stats.rating}}</view>
        <view class="stats-label">服务评分</view>
      </view>
    </view>
  </view>
</view>