<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 欢迎标题 -->
  <view class="card">
    <view class="title">快递帮取服务</view>
    <view class="text">让快递收取更便捷，互帮互助的社区服务</view>
  </view>

  <!-- 主要功能菜单 -->
  <view class="menu-grid">
    <view class="menu-item" bindtap="goToHelpDeliver">
      <view class="menu-icon">📦</view>
      <view class="menu-text">我帮取快递</view>
    </view>

    <view class="menu-item" bindtap="goToHavePackage">
      <view class="menu-icon">📮</view>
      <view class="menu-text">我有快递</view>
    </view>

    <view class="menu-item" bindtap="handleLogin" wx:if="{{!isLoggedIn}}">
      <view class="menu-icon">🔑</view>
      <view class="menu-text">登录</view>
    </view>

    <view class="menu-item" bindtap="handleLogout" wx:if="{{isLoggedIn}}">
      <view class="menu-icon">🚪</view>
      <view class="menu-text">登出</view>
    </view>
  </view>

  <!-- 用户状态显示 -->
  <view class="card" wx:if="{{isLoggedIn}}">
    <view class="title">欢迎回来！</view>
    <view class="text">{{userInfo.nickName || '用户'}}</view>
  </view>

  <view class="card" wx:if="{{!isLoggedIn}}">
    <view class="title">请先登录</view>
    <view class="text">登录后即可使用完整的快递帮取服务</view>
  </view>
</view>