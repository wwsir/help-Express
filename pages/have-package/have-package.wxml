<!-- pages/have-package/have-package.wxml -->
<view class="container">
  <view class="card">
    <view class="title">我有快递</view>
    <view class="text">发布快递代取需求，让别人帮你取快递</view>
  </view>

  <!-- 发布新需求表单 -->
  <view class="form-section">
    <view class="form-title">发布代取需求</view>
    
    <view class="form-item">
      <view class="form-label">快递信息</view>
      <input class="form-input" placeholder="请输入快递公司和物品类型" value="{{formData.title}}" bindinput="onTitleInput" />
    </view>

    <view class="form-item">
      <view class="form-label">取件地址</view>
      <input class="form-input" placeholder="请输入具体的取件地址" value="{{formData.location}}" bindinput="onLocationInput" />
    </view>

    <view class="form-item">
      <view class="form-label">包裹大小</view>
      <picker bindchange="onSizeChange" value="{{sizeIndex}}" range="{{sizeRange}}">
        <view class="form-picker">{{sizeRange[sizeIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">要求时间</view>
      <picker mode="datetime" bindchange="onDeadlineChange" value="{{formData.deadline}}">
        <view class="form-picker">{{formData.deadline || '请选择取件时间'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">服务费用</view>
      <input class="form-input" type="number" placeholder="请输入愿意支付的服务费" value="{{formData.price}}" bindinput="onPriceInput" />
    </view>

    <view class="form-item">
      <view class="form-label">备注说明</view>
      <textarea class="form-textarea" placeholder="请输入详细说明，如包裹重量、注意事项等" value="{{formData.description}}" bindinput="onDescriptionInput"></textarea>
    </view>

    <button class="btn" bindtap="publishRequest">发布需求</button>
  </view>

  <!-- 我的需求列表 -->
  <view class="my-requests">
    <view class="section-title">我的发布</view>
    
    <view class="request-list">
      <view class="request-item" wx:for="{{myRequests}}" wx:key="id">
        <view class="request-info">
          <view class="request-title">{{item.title}}</view>
          <view class="request-detail">
            <text class="detail-text">📍 {{item.location}}</text>
            <text class="detail-text">⏰ {{item.deadline}}</text>
            <text class="detail-text">💰 ¥{{item.price}}元</text>
          </view>
          <view class="request-status status-{{item.status}}">{{item.statusText}}</view>
        </view>
        <view class="request-actions">
          <button class="action-btn" wx:if="{{item.status === 'pending'}}" bindtap="cancelRequest" data-id="{{item.id}}">取消</button>
          <button class="action-btn" wx:if="{{item.status === 'accepted'}}" bindtap="contactHelper" data-id="{{item.id}}">联系</button>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{myRequests.length === 0}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">暂无发布记录</view>
      <view class="empty-desc">发布第一个代取需求吧</view>
    </view>
  </view>
</view>